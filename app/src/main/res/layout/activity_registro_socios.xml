<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#15191C"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="8dp"
    tools:ignore="UseCompoundDrawables,TextContrastCheck,SpeakableTextPresentCheck">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/socio_titulo_pantalla"
        android:textColor="#9CA3AF"
        android:textSize="14sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            tools:ignore="ScrollViewSize">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="16dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp">

                <!-- Encabezado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    tools:ignore="Accessibility">

                    <ImageView
                        android:id="@+id/btnVolver"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:clickable="true"
                        android:contentDescription="@string/volver"
                        android:focusable="true"
                        android:padding="12dp"
                        android:src="@drawable/arrow_back_24px" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:letterSpacing="0.08"
                        android:text="@string/socio_titulo"
                        android:textColor="#111111"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/opciones"
                        android:padding="12dp"
                        android:src="@drawable/more_vert_24px" />

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="30dp" />

                <!-- Información del cliente -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:minHeight="32dp"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="26dp"
                        android:background="#111111" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:letterSpacing="0.08"
                        android:text="@string/socio_info_cliente"
                        android:textColor="#111111"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="18dp" />

                <!-- Formulario principal -->
                <LinearLayout
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="vertical"
                    tools:ignore="Accessibility">

                    <!-- Nombre / Apellido -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.08"
                                android:text="@string/socio_nombre"
                                android:textColor="#4B5563"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <EditText
                                android:id="@+id/nombre"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="4dp"
                                android:autofillHints="name"
                                android:background="#F3F4F6"
                                android:hint="@string/socio_nombre_hint"
                                android:inputType="textPersonName"
                                android:minHeight="48dp"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:textColor="#111111"
                                android:textColorHint="#4B5563"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.08"
                                android:text="@string/socio_apellido"
                                android:textColor="#4B5563"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <EditText
                                android:id="@+id/apellido"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="4dp"
                                android:autofillHints="familyName"
                                android:background="#F3F4F6"
                                android:hint="@string/socio_apellido_hint"
                                android:inputType="textPersonName"
                                android:minHeight="48dp"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:textColor="#111111"
                                android:textColorHint="#4B5563"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="12dp" />

                    <!-- Tipo documento / DNI -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.08"
                                android:text="@string/socio_tipo_documento"
                                android:textColor="#4B5563"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <AutoCompleteTextView
                                android:id="@+id/tipoDocumento"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="4dp"
                                android:background="@drawable/bg_dropdown_figma"
                                android:drawableEnd="@drawable/arrow_drop_down_24"
                                android:drawablePadding="8dp"
                                android:focusable="false"
                                android:importantForAutofill="no"
                                android:inputType="none"
                                android:minHeight="48dp"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:singleLine="true"
                                android:text="@string/socio_tipo_documento_valor"
                                android:textColor="#111111"
                                android:textSize="13sp"
                                tools:ignore="DuplicateSpeakableTextCheck,SpeakableTextPresentCheck" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.08"
                                android:text="@string/socio_dni"
                                android:textColor="#4B5563"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <EditText
                                android:id="@+id/dni"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="4dp"
                                android:autofillHints="username"
                                android:background="#F3F4F6"
                                android:hint="@string/socio_dni_hint"
                                android:inputType="number"
                                android:minHeight="48dp"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:textColor="#111111"
                                android:textColorHint="#4B5563"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="12dp" />

                    <!-- Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="@string/socio_email"
                        android:textColor="#4B5563"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/email"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:autofillHints="emailAddress"
                        android:background="#F3F4F6"
                        android:hint="@string/socio_email_hint"
                        android:inputType="textEmailAddress"
                        android:minHeight="48dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="#111111"
                        android:textColorHint="#4B5563"
                        android:textSize="13sp" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="12dp" />

                    <!-- Teléfono -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="@string/socio_telefono"
                        android:textColor="#4B5563"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/telefono"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:autofillHints="phone"
                        android:background="#F3F4F6"
                        android:hint="@string/socio_telefono_hint"
                        android:inputType="phone"
                        android:minHeight="48dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="#111111"
                        android:textColorHint="#4B5563"
                        android:textSize="13sp" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="14dp" />

                    <!-- Apto físico -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="#F3F4F6"
                        android:baselineAligned="false"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingEnd="8dp">

                        <CheckBox
                            android:id="@+id/aptoFisico"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:buttonTint="#4B5563"
                            android:contentDescription="@string/socio_apto_fisico" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.08"
                            android:text="@string/socio_apto_fisico"
                            android:textColor="#111111"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/campo_obligatorio"
                            android:textColor="#B91C1C"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="28dp" />

                <!-- Detalles del pago -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:minHeight="32dp"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="26dp"
                        android:background="#111111" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:letterSpacing="0.08"
                        android:text="@string/socio_detalles_pago"
                        android:textColor="#111111"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="18dp" />

                <!-- Pago -->
                <LinearLayout
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.08"
                            android:text="@string/socio_modo_pago"
                            android:textColor="#4B5563"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <AutoCompleteTextView
                            android:id="@+id/modo_pago"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_dropdown_figma"
                            android:drawableEnd="@drawable/arrow_drop_down_24"
                            android:drawablePadding="8dp"
                            android:focusable="false"
                            android:importantForAutofill="no"
                            android:inputType="none"
                            android:minHeight="48dp"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:singleLine="true"
                            android:text="@string/socio_modo_pago_valor"
                            android:textColor="#111111"
                            android:textSize="13sp"
                            tools:ignore="DuplicateSpeakableTextCheck,SpeakableTextPresentCheck" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.08"
                            android:text="@string/socio_total_pagar"
                            android:textColor="#4B5563"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/monto_pagar"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:gravity="center_vertical"
                            android:text="@string/socio_monto_pagar"
                            android:textColor="#111111"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="30dp" />

                <!-- Botón registrar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegistrarSocio"
                    android:layout_width="300dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center_horizontal"
                    android:backgroundTint="#000000"
                    android:letterSpacing="0.08"
                    android:text="@string/socio_registrar"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/person_add_24px"
                    app:iconGravity="textStart"
                    app:iconPadding="10dp"
                    app:iconSize="24dp"
                    app:iconTint="#FFFFFF" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="12dp" />

                <!-- Botón cancelar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelar"
                    android:layout_width="300dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center_horizontal"
                    android:backgroundTint="#FFFFFF"
                    android:letterSpacing="0.10"
                    android:text="@string/cancelar"
                    android:textColor="#111111"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp" />

            </LinearLayout>

        </ScrollView>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>