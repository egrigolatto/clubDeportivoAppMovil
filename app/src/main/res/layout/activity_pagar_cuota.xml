<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/fondo"
    android:padding="30dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="55dp"
            >

            <ImageView
                android:id="@+id/btnVolver"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_marginRight="60dp"
                android:src="@drawable/arrow_back_24px"
                android:contentDescription="arrowback"
                android:clickable="true"
                android:focusable="true"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="PAGAR CUOTA"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginRight="50dp"
                android:letterSpacing="0.1"
                />

            <ImageView
                android:layout_width="30dp"
                android:layout_height="match_parent"
                android:src="@drawable/more_vert_24px"
                android:layout_gravity="center"
                android:contentDescription="settings"
                />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ingrese los datos para procesar el pago administrativo."
            android:textColor="@color/color_3"
            android:textSize="12sp"
            android:textStyle="italic"
            android:gravity="center"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="40dp"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="40dp"
            >
            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_marginRight="5dp"
                android:src="@drawable/ic_rectangulo"
                android:contentDescription="barra"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="INFORMACION DEL CLIENTE"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.1"
                />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DNI DEL CLIENTE"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_3"
                android:layout_marginRight="10dp"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="*"
                android:textSize="18sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_2"
                />
        </LinearLayout>
        <EditText
            android:id="@+id/dniCliente"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textColor="@color/color_3"
            android:backgroundTint="@color/color_5"
            android:layout_marginBottom="10dp"
            />

        <TextView
            android:id="@+id/mensajeError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/color_2"
            android:text="hola"
            android:textSize="15sp"
            android:visibility="invisible"
            android:layout_marginBottom="40dp"
            android:layout_marginStart="10dp"
            />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Validación de Identidad"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="40dp"

            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="00dp"
            android:gravity="center"
            android:layout_marginBottom="80dp"
            >
            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/error_24px"
                android:layout_margin="20dp"
                />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Asegúrese de que el DNI coincida exactamente con
la ficha del cliente en el sistema central."
                android:textColor="@color/color_3"
                android:textSize="14sp"
                android:textStyle="italic"
                android:layout_marginLeft="10dp"
                android:gravity="start"
                />
        </LinearLayout>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONFIRMAR"
            android:backgroundTint="@color/black"
            android:padding="20dp"
            android:textSize="20sp"
            android:layout_marginTop="20dp"
            android:gravity="center"

            app:cornerRadius="16dp"

            android:layout_marginBottom="20dp"
            />

        <LinearLayout
            android:id="@+id/btnCancelar"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CANCELAR"
                android:textSize="20sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.1"
                />



        </LinearLayout>
    </LinearLayout>
</ScrollView>