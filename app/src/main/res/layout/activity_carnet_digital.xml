<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/fondo"
    android:padding="30dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="55dp"
            >

            <ImageView
                android:id="@+id/btnVolver"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_marginRight="20dp"
                android:src="@drawable/arrow_back_24px"
                android:contentDescription="arrowback"
                android:clickable="true"
                android:focusable="true"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="CARNET DIGITAL"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginRight="50dp"
                android:letterSpacing="0.1"
                />

            <ImageView
                android:layout_width="30dp"
                android:layout_height="match_parent"
                android:src="@drawable/more_vert_24px"
                android:layout_gravity="center"
                android:contentDescription="settings"
                />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="50dp"
            >
            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_marginRight="5dp"
                android:src="@drawable/ic_rectangulo"
                android:contentDescription="barra"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="SOCIO ACTIVO"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:layout_marginRight="40dp"
                />
            <TextView
                android:id="@+id/nrodni"
                android:layout_width="150dp"
                android:layout_height="match_parent"
                android:text="N° 12345678"
                android:gravity="center"
                android:textColor="@color/fondo"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@color/black"
                android:padding="5dp"
                android:letterSpacing="0.1"

                />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOMBRE DEL SOCIO"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/color_3"
            android:layout_marginStart="40dp"
            android:layout_marginBottom="10dp"
            />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="0dp"
            android:layout_marginStart="40dp"
            >

            <TextView
                android:id="@+id/nombreSocio"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="JUAN GOMEZ"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginRight="60dp"
                android:letterSpacing="0.1"
                />

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/qr_code_24px"
                android:layout_gravity="center"
                android:contentDescription="settings"
                />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:gravity="center"
            >
            <ImageView
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/account_box_24px"
                android:layout_gravity="center"
                android:contentDescription="foto"
                />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            android:gravity="start">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FECHA DE ALTA"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_3"
                android:layout_marginRight="100dp"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ESTADO"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_3"
                />


        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="30dp"
            android:gravity="center"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="16/08/25"
                android:textSize="16sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginRight="40dp"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VÁLIDO HASTA 2026"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:drawableStart="@drawable/verified_24px"
                />


        </LinearLayout>

        <TextView
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Presenta este carnet para acceder a las
instalaciones del club."
            android:textColor="@color/color_3"
            android:gravity="center"
            android:textSize="12dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCompartir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COMPARTIR"
            android:backgroundTint="@color/black"
            android:padding="20dp"
            android:textSize="20sp"
            android:layout_marginTop="20dp"
            android:gravity="center"

            app:cornerRadius="16dp"

            app:icon="@drawable/share_24px"
            app:iconGravity="textStart"

            app:iconSize="32dp"
            android:layout_marginBottom="20dp"
            />




    </LinearLayout>
</ScrollView>