<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/fondo"
    android:padding="30dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="55dp"
            >

            <ImageView
                android:id="@+id/btnVolver"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_marginRight="0dp"
                android:src="@drawable/arrow_back_24px"
                android:contentDescription="arrowback"
                android:clickable="true"
                android:focusable="true"
                />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginRight="0dp"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:text="PAGAR CUOTA DIARIA"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NO SOCIO"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/color_1"
            android:layout_marginBottom="16dp"
            />
        <TextView
            android:id="@+id/nombreSocio"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="RODRIGUEZ EMMA"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:layout_marginBottom="20dp"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SELECCIONAR ACTIVIDADES"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/color_3"
            android:layout_marginBottom="20dp"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="5dp"
            >

            <LinearLayout
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Natación"
                    android:textSize="20sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acceso Diario"
                    android:textColor="@color/color_5"
                    android:textSize="14sp"
                    />
            </LinearLayout>
            <TextView
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:text="$ 10.000"
                android:textColor="@color/color_4"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginRight="40dp"
                android:gravity="center"
                />
            <CheckBox
                android:id="@+id/checkNatacion"
                android:layout_width="35dp"
                android:layout_height="match_parent"
                android:textColor="@color/color_5"
                android:layout_marginRight="10dp"
                />


        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="5dp"
            >

            <LinearLayout
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Musculación"
                    android:textSize="20sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acceso Diario"
                    android:textColor="@color/color_5"
                    android:textSize="14sp"
                    />
            </LinearLayout>
            <TextView
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:text="$ 13.000"
                android:textColor="@color/color_4"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginRight="40dp"
                android:gravity="center"
                />
            <CheckBox
                android:id="@+id/checkMusculacion"
                android:layout_width="35dp"
                android:layout_height="match_parent"
                android:textColor="@color/color_5"
                android:layout_marginRight="10dp"
                />


        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="5dp"
            >

            <LinearLayout
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Yoga"
                    android:textSize="20sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acceso Diario"
                    android:textColor="@color/color_5"
                    android:textSize="14sp"
                    />
            </LinearLayout>
            <TextView
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:text="$ 15.000"
                android:textColor="@color/color_4"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginRight="40dp"
                android:gravity="center"
                />
            <CheckBox
                android:id="@+id/checkYoga"
                android:layout_width="35dp"
                android:layout_height="match_parent"
                android:textColor="@color/color_5"
                android:layout_marginRight="10dp"
                />


        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            >

            <LinearLayout
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pilates"
                    android:textSize="20sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acceso Diario"
                    android:textColor="@color/color_5"
                    android:textSize="14sp"
                    />
            </LinearLayout>
            <TextView
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:text="$ 18.000"
                android:textColor="@color/color_4"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginRight="40dp"
                android:gravity="center"
                />
            <CheckBox
                android:id="@+id/checkPilates"
                android:layout_width="35dp"
                android:layout_height="match_parent"
                android:textColor="@color/color_5"
                android:layout_marginRight="10dp"
                />


        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MODO DE PAGO"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/color_3"
            android:layout_marginBottom="5dp"
            />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            app:endIconMode="dropdown_menu"
            app:cornerRadius="0dp"

            android:elevation="0dp"
            app:elevation="0dp"
            android:backgroundTint="@color/color_5"
            android:layout_marginBottom="20dp"
            >


            <AutoCompleteTextView
                android:id="@+id/modopago"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:paddingStart="10dp"
                android:inputType="none"
                />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EL TOTAL A PAGAR ES:"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/color_3"
            android:layout_marginBottom="10dp"
            android:gravity="center"
            />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="$ 0.00"
            android:textColor="@color/color_4"
            android:textSize="34sp"
            android:textStyle="bold"

            android:gravity="center"
            />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPagarCuota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONFIRMAR PAGO"
            android:backgroundTint="@color/black"
            android:padding="20dp"
            android:textSize="20sp"
            android:layout_marginTop="20dp"
            android:gravity="center"

            app:cornerRadius="16dp"

            android:layout_marginBottom="20dp"
            />

        <LinearLayout
            android:id="@+id/btnCancelar"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CANCELAR"
                android:textSize="20sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.1"
                />



        </LinearLayout>



    </LinearLayout>
</ScrollView>