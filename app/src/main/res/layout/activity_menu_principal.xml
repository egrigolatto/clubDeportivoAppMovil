<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/fondo"
    android:padding="30dp">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="65dp"
        >

        <ImageView
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginRight="5dp"
            android:src="@drawable/ic_rectangulo"
            android:contentDescription="barra"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="CLUB DEPORTIVO"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginRight="70dp"
            android:letterSpacing="0.1"
            />

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/settings_24px"
            android:layout_gravity="center"
            android:contentDescription="settings"
            />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROL: "
                android:layout_marginBottom="5dp"
                android:textSize="14sp"
                android:textColor="@color/color_3"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginStart="25dp"
                />
            <TextView
                android:id="@+id/rol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADMINISTRADOR"
                android:layout_marginBottom="5dp"
                android:textSize="14sp"
                android:textColor="@color/color_3"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginStart="4dp"
                />
        </LinearLayout>

    <TextView
        android:id="@+id/usuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User: user_01"
        android:textColor="@color/color_3"
        android:textStyle="italic"
        android:layout_marginBottom="50dp"
        android:layout_marginStart="25dp"
        android:textSize="14sp"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MENÚ PRINCIPAL"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="28sp"
        android:layout_marginBottom="20dp"
        android:layout_marginStart="25dp"
        />

        <LinearLayout
            android:id="@+id/cardRegistrarSocio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="15dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="start"
            >

            <TextView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:text="01"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="@color/color_3"
                android:textStyle="bold"
                />

            <TextView
                android:layout_width="225dp"
                android:layout_height="wrap_content"
                android:text="REGISTRAR SOCIO"
                android:backgroundTint="@color/fondo"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:layout_marginStart="10dp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                />

            <ImageView
                android:layout_width="10dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:src="@drawable/arrow_forward_ios_24px"
                android:contentDescription="imag"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardRegistrarNoSocio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="15dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="start"
            >

            <TextView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:text="02"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="@color/color_3"
                android:textStyle="bold"
                />

            <TextView
                android:layout_width="225dp"
                android:layout_height="wrap_content"
                android:text="REGISTRAR NO SOCIO"
                android:backgroundTint="@color/fondo"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:layout_marginStart="10dp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                />

            <ImageView
                android:layout_width="10dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:src="@drawable/arrow_forward_ios_24px"
                android:contentDescription="img"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardPagarCuota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="15dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="start"
            >

            <TextView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:text="03"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="@color/color_3"
                android:textStyle="bold"
                />

            <TextView
                android:layout_width="225dp"
                android:layout_height="wrap_content"
                android:text="PAGAR CUOTA"
                android:backgroundTint="@color/fondo"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:layout_marginStart="10dp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                />

            <ImageView
                android:layout_width="10dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:src="@drawable/arrow_forward_ios_24px"
                android:contentDescription="img"
                />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/cardListaMorosos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="15dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="start"
            >

            <TextView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:text="04"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="@color/color_3"
                android:textStyle="bold"
                />

            <TextView
                android:layout_width="225dp"
                android:layout_height="wrap_content"
                android:text="LISTA MOROSOS"
                android:backgroundTint="@color/fondo"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:layout_marginStart="10dp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                />

            <ImageView
                android:layout_width="10dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:src="@drawable/arrow_forward_ios_24px"
                android:contentDescription="img"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardRegistrarAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="15dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="start"
            >

            <TextView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:text="05"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="@color/color_3"
                android:textStyle="bold"
                />

            <TextView
                android:layout_width="225dp"
                android:layout_height="wrap_content"
                android:text="REGISTRAR ADMIN"
                android:backgroundTint="@color/fondo"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:layout_marginStart="10dp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                />

            <ImageView
                android:layout_width="10dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:src="@drawable/arrow_forward_ios_24px"
                android:contentDescription="img"
                />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalirApp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SALIR DEL SISTEMA"
            android:backgroundTint="@color/color_5"
            android:padding="20dp"
            android:textSize="20sp"
            android:layout_marginTop="20dp"
            android:gravity="start"

            app:cornerRadius="16dp"

            app:icon="@drawable/exit_to_app_24px"
            app:iconGravity="textStart"
            app:iconPadding="30dp"
            app:iconSize="32dp"
            />

    </LinearLayout>



</LinearLayout>
</ScrollView>