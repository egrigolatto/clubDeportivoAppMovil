<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#15191C"
    android:fillViewport="true"
    tools:ignore="ScrollViewSize,UseCompoundDrawables">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_principal_titulo_pantalla"
            android:textColor="#9CA3AF"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="34dp"
                android:paddingEnd="24dp"
                android:paddingBottom="34dp">

                <!-- Encabezado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="26dp"
                        android:background="#111111" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:letterSpacing="0.10"
                        android:text="@string/club_deportivo"
                        android:textColor="#111111"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/configuracion"
                        android:padding="12dp"
                        android:src="@drawable/settings_24px" />

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="46dp" />

                <!-- Datos del usuario -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:letterSpacing="0.10"
                    android:text="@string/rol_administrador"
                    android:textColor="#4B5563"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:layout_marginTop="4dp"
                    android:text="@string/usuario_actual"
                    android:textColor="#4B5563"
                    android:textSize="12sp"
                    android:textStyle="italic" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="38dp" />

                <!-- Título -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:text="@string/menu_principal"
                    android:textColor="#111111"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

                <!-- Opción 01 -->
                <LinearLayout
                    android:id="@+id/cardRegistrarSocio"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:baselineAligned="false"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/menu_numero_01"
                        android:textColor="#4B5563"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:letterSpacing="0.08"
                        android:text="@string/registrar_socio"
                        android:textColor="#111111"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/ir"
                        android:padding="6dp"
                        android:src="@drawable/arrow_forward_ios_24px" />

                </LinearLayout>

                <!-- Opción 02 -->
                <LinearLayout
                    android:id="@+id/cardRegistrarNoSocio"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:baselineAligned="false"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/menu_numero_02"
                        android:textColor="#4B5563"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:letterSpacing="0.08"
                        android:text="@string/registrar_no_socio"
                        android:textColor="#111111"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/ir"
                        android:padding="6dp"
                        android:src="@drawable/arrow_forward_ios_24px" />

                </LinearLayout>

                <!-- Opción 03 -->
                <LinearLayout
                    android:id="@+id/cardPagarCuota"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:baselineAligned="false"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/menu_numero_03"
                        android:textColor="#4B5563"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:letterSpacing="0.08"
                        android:text="@string/pagar_cuota"
                        android:textColor="#111111"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/ir"
                        android:padding="6dp"
                        android:src="@drawable/arrow_forward_ios_24px" />

                </LinearLayout>

                <!-- Opción 04 -->
                <LinearLayout
                    android:id="@+id/cardListaMorosos"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:baselineAligned="false"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/menu_numero_04"
                        android:textColor="#4B5563"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:letterSpacing="0.08"
                        android:text="@string/lista_morosos"
                        android:textColor="#111111"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/ir"
                        android:padding="6dp"
                        android:src="@drawable/arrow_forward_ios_24px" />

                </LinearLayout>

                <!-- Opción 05 -->
                <LinearLayout
                    android:id="@+id/cardRegistrarAdmin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:baselineAligned="false"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/menu_numero_05"
                        android:textColor="#4B5563"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:letterSpacing="0.08"
                        android:text="@string/registrar_admin"
                        android:textColor="#111111"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/ir"
                        android:padding="6dp"
                        android:src="@drawable/arrow_forward_ios_24px" />

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Botón salir -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSalirApp"
                    android:layout_width="300dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center_horizontal"
                    android:backgroundTint="#3F3F46"
                    android:text="@string/salir_del_sistema"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/exit_to_app_24px"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconSize="24dp"
                    app:iconTint="#FFFFFF" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>