<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/fondo"
    android:padding="30dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="55dp"
            >

            <ImageView
                android:id="@+id/btnVolver"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_marginRight="0dp"
                android:src="@drawable/arrow_back_24px"
                android:contentDescription="arrowback"
                android:clickable="true"
                android:focusable="true"
                />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginRight="0dp"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:text="PAGAR CUOTA MENSUAL"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IDENTIFICACIÓN DEL CLIENTE"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/color_3"
            android:layout_marginBottom="20dp"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start"
            android:layout_marginBottom="30dp"
            >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Socio: "
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:layout_marginRight="10dp"
                />
            <TextView
                android:id="@+id/nombreSocio"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="JUAN GOMEZ"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.1"
                />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_3"
                android:layout_marginRight="70dp"

                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VENCIMIENTO"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_3"
                android:layout_marginRight="70dp"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRECIO"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_3"

                />
        </LinearLayout>
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/black"
            android:layout_marginVertical="10dp"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01"
                android:textSize="24sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_5"
                android:layout_marginRight="70dp"

                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10/12/2025"
                android:textSize="16sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_3"
                android:layout_marginRight="70dp"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20.000"
                android:textSize="18sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/black"

                />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="02"
                android:textSize="24sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_5"
                android:layout_marginRight="70dp"

                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10/12/2025"
                android:textSize="16sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_3"
                android:layout_marginRight="70dp"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20.000"
                android:textSize="18sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/black"

                />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="03"
                android:textSize="24sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_5"
                android:layout_marginRight="70dp"

                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10/12/2025"
                android:textSize="16sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_3"
                android:layout_marginRight="70dp"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20.000"
                android:textSize="18sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/black"

                />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="04"
                android:textSize="24sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_5"
                android:layout_marginRight="70dp"

                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10/12/2025"
                android:textSize="16sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/color_3"
                android:layout_marginRight="70dp"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20.000"
                android:textSize="18sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/black"

                />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/black"
            android:layout_marginVertical="10dp"
            />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RESUMEN DE PAGO"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/color_3"
            android:gravity="center"
            android:layout_marginTop="10dp"

            />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="El monto total a pagar es:"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/color_3"
            android:gravity="center"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="10dp"
            />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="$  80.000"
            android:textSize="34sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/color_4"
            android:gravity="center"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="10dp"
            />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPagarCuota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONFIRMAR PAGO"
            android:backgroundTint="@color/black"
            android:padding="20dp"
            android:textSize="20sp"
            android:layout_marginTop="20dp"
            android:gravity="center"

            app:cornerRadius="16dp"

            android:layout_marginBottom="20dp"
            />

        <LinearLayout
            android:id="@+id/btnCancelar"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CANCELAR"
                android:textSize="20sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.1"
                />



        </LinearLayout>
    </LinearLayout>
</ScrollView>