<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#15191C"
    android:fillViewport="true"
    tools:ignore="ScrollViewSize,UseCompoundDrawables">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/socios_morosos"
            android:textColor="#9CA3AF"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="24dp"
                android:paddingEnd="22dp"
                android:paddingBottom="24dp">

                <!-- Barra superior -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/btnVolver"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:clickable="true"
                        android:contentDescription="@string/volver"
                        android:focusable="true"
                        android:padding="12dp"
                        android:src="@drawable/arrow_back_24px" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:letterSpacing="0.04"
                        android:text="@string/lista_morosos"
                        android:textColor="#111111"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/opciones"
                        android:padding="12dp"
                        android:src="@drawable/more_vert_24px" />

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="50dp" />


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvMorosos"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"/>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Mensaje sin registros -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNoResultados"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="138dp"
                    app:cardBackgroundColor="#F9FAFB"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="138dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingTop="18dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="18dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="@string/sin_registros"
                            android:src="@drawable/error_24px" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center"
                            android:text="@string/no_hay_mas_registros"
                            android:textColor="#374151"
                            android:textSize="13sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Botón volver -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVolverMenu"
                    android:layout_width="300dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center_horizontal"
                    android:backgroundTint="#111111"
                    android:text="@string/volver_mayuscula"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:cornerRadius="18dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>