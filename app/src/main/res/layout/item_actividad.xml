<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
xmlns:android="http://schemas.android.com/apk/res/android"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:minHeight="56dp"
android:baselineAligned="false"
android:gravity="center_vertical"
android:orientation="horizontal">

<LinearLayout
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:orientation="vertical">

    <TextView
        android:id="@+id/nombreActividad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/actividad_natacion"
        android:textColor="#111111"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/acceso_diario"
        android:textColor="#4B5563"
        android:textSize="12sp" />

</LinearLayout>

<TextView
    android:id="@+id/precioActividad"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="92dp"
    android:gravity="end"
    android:text="@string/precio_natacion"
    android:textColor="#0A66C2"
    android:textSize="14sp"
    android:textStyle="bold" />

<CheckBox
    android:id="@+id/checkActividad"
    android:layout_width="56dp"
    android:layout_height="56dp"
    android:minWidth="56dp"
    android:minHeight="56dp"
    android:button="@drawable/selector_checkbox_redondeado"
    android:contentDescription="@string/seleccionar_natacion" />

</LinearLayout>