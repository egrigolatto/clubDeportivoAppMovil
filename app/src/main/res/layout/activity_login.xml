<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#15191C"
    android:fillViewport="true"
    tools:ignore="ScrollViewSize,UseCompoundDrawables">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/iniciar_sesion_titulo"
            android:textColor="#9CA3AF"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="34dp"
                android:paddingEnd="24dp"
                android:paddingBottom="34dp">

                <!-- Logo y nombre del club -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_marginEnd="28dp"
                        android:contentDescription="@string/logo_club"
                        android:src="@drawable/logo_24px" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:letterSpacing="0.10"
                        android:text="@string/club_deportivo"
                        android:textColor="#111111"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="46dp" />

                <!-- Acceso usuarios -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.16"
                    android:text="@string/acceso_usuarios"
                    android:textColor="#4B5563"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="34dp" />

                <!-- Iniciar sesión -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/iniciar_sesion"
                    android:textColor="#111111"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="32dp" />

                <!-- Usuario -->
                <LinearLayout
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="@string/usuario"
                        android:padding="4dp"
                        android:src="@drawable/person_24px" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/usuario"
                        android:textColor="#111111"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <EditText
                    android:id="@+id/usuario"
                    android:layout_width="300dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center_horizontal"
                    android:autofillHints="username"
                    android:backgroundTint="#6B7280"
                    android:hint="@string/numero_documento_hint"
                    android:inputType="number"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:textColor="#111111"
                    android:textColorHint="#6B7280"
                    android:textSize="16sp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="22dp" />

                <!-- Contraseña -->
                <LinearLayout
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="@string/contrasena"
                        android:padding="4dp"
                        android:src="@drawable/lock_24px" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/contrasena"
                        android:textColor="#111111"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <EditText
                    android:id="@+id/password"
                    android:layout_width="300dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center_horizontal"
                    android:autofillHints="password"
                    android:backgroundTint="#6B7280"
                    android:hint="@string/password_hint"
                    android:inputType="textPassword"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:textColor="#111111"
                    android:textColorHint="#6B7280"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/mensajeErrorLogin"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:text="@string/error_login"
                    android:textColor="#DC2626"
                    android:textSize="14sp"
                    android:visibility="invisible" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="42dp" />

                <!-- Botón ingresar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIngresar"
                    android:layout_width="300dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center_horizontal"
                    android:backgroundTint="#0A66C2"
                    android:text="@string/ingresar"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>